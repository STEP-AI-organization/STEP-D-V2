{
  "name": "@stepd/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "STEP-D backend — Hono + node:sqlite + ffmpeg",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "start": "tsx --env-file .env src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "worker": "tsx --env-file-if-exists=.env src/worker.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.15.0",
    "@hono/node-server": "^1.13.7",
    "google-auth-library": "^9.15.0",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "typescript": "^5"
  }
}
