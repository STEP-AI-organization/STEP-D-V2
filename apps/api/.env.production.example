# Production env for the GCP VM. Copy to apps/api/.env.production and fill in.
# Used both as docker compose --env-file (for ${...} interpolation) and as the
# api service env_file. Keep this file out of git and chmod 600 on the VM.
#
#   cp apps/api/.env.production.example apps/api/.env.production
#   nano apps/api/.env.production
#   docker compose --env-file apps/api/.env.production -f docker-compose.prod.yml up -d --build

# ─── Deploy-level (compose interpolation + cloud-sql-proxy/Caddy) ────────────
# Cloud SQL instance connection name: PROJECT:REGION:INSTANCE
INSTANCE_CONNECTION_NAME=my-project:asia-northeast3:shorts-pg
# Public API domain (Caddy issues a cert for this; DNS A -> VM static IP first).
API_DOMAIN=api.stepai.kr
# Email for Let's Encrypt expiry notices.
ACME_EMAIL=hkj@stepai.kr
# Host path of the mounted persistent SSD that backs /data inside the container.
DATA_DIR=/data

# ─── Storage backend ────────────────────────────────────────────────────────
STORAGE_BACKEND=gcs
GCS_BUCKET=stepai-shorts-media
# Optional CDN / custom domain in front of the bucket. Leave empty to use
# https://storage.googleapis.com/<bucket>/<key>.
GCS_PUBLIC_BASE_URL=
GCS_PREFIX=prod

# ─── Database (via cloud-sql-proxy sidecar at host "cloud-sql-proxy") ────────
DATABASE_URL=postgresql+psycopg2://shorts:CHANGE_ME@cloud-sql-proxy:5432/shorts

# ─── Public URLs / CORS (cross-site Vercel web -> API) ──────────────────────
PUBLIC_BASE_URL=https://api.stepai.kr
CORS_ORIGINS=["https://app.stepai.kr"]
WEB_BASE_URL=https://app.stepai.kr

# ─── Secrets / model APIs ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_LANGUAGE=ko
OPENAI_TRANSCRIBE_PROMPT=Korean broadcast, variety show, interview, and talk show footage. Preserve proper nouns and casual speech as spoken.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_EVAL_CANDIDATES=12

# ─── Google OAuth (login + YouTube). Register BOTH redirect URIs in the OAuth
#     client and add app.stepai.kr to Authorized JS origins. ─────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
AUTH_OAUTH_REDIRECT_URI=https://api.stepai.kr/api/auth/google/callback
YOUTUBE_OAUTH_REDIRECT_URI=https://api.stepai.kr/api/youtube/oauth/callback
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
YOUTUBE_CATEGORY_ID=24
YOUTUBE_DEFAULT_PRIVACY_STATUS=public
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=600

# Optional: yt-dlp cookies (Netscape format) to reduce 429s from the server IP.
# Mount the file into the api container and point at it, e.g. /data/yt-cookies.txt
YTDLP_COOKIES_FILE=

# ─── Pipeline / rendering (same defaults as local) ──────────────────────────
MAX_UPLOAD_MB=2048
MAX_CANDIDATE_COUNT=30
FINAL_CLIP_COUNT=8
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90
TARGET_CLIP_SECONDS=45
BOUNDARY_REFINE_ENABLED=true
BOUNDARY_MAX_SECONDS=70
FFMPEG_AUDIO_FILTER=loudnorm=I=-16:TP=-1.5:LRA=11,highpass=f=80,lowpass=f=12000
RENDER_VERTICAL_SHORTS=true
SHORTS_REFRAME_MODE=blur
SHORTS_WIDTH=1080
SHORTS_HEIGHT=1920
SHORTS_BACKGROUND_COLOR=black
SHORTS_BLUR_BACKGROUND_STRENGTH=24
SHORTS_SUBTITLES_ENABLED=true
SHORTS_STYLE_PRESET_DEFAULT=korean_pop
SHORTS_SUBTITLE_MODE_DEFAULT=auto
SHORTS_SUBTITLE_FONT_NAME=G마켓 산스 TTF Bold
SHORTS_SUBTITLE_FONTS_DIR=
SHORTS_SUBTITLE_FONT_SIZE=70
SHORTS_SUBTITLE_MARGIN_V=220
SHORTS_SUBTITLE_MAX_CHARS_PER_LINE=16
SHORTS_SUBTITLE_MAX_LINES=2
SHORTS_SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SHORTS_SUBTITLE_HIGHLIGHT_ENABLED=true
SHORTS_SUBTITLE_HIGHLIGHT_COLOR=&H0000E6FF
SHORTS_SUBTITLE_OUTLINE=5
SHORTS_SUBTITLE_SHADOW=2
BURNED_IN_CAPTION_DETECTION_ENABLED=true
BURNED_IN_CAPTION_DETECTION_MAX_FRAMES=6
BURNED_IN_CAPTION_DETECTION_CONFIDENCE_THRESHOLD=0.72
