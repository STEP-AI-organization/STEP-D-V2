# Local Docker Compose defaults.
# Copy values into .env or pass them from your cloud secret manager.

OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_LANGUAGE=ko
OPENAI_TRANSCRIBE_PROMPT=Korean broadcast, variety show, interview, and talk show footage. Preserve proper nouns and casual speech as spoken.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_EVAL_CANDIDATES=12

# Browser-visible API URL. In local compose this is the host-mapped API port.
PUBLIC_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Google OAuth / YouTube channel connection.
# In cloud, replace these with your real API and web domains and register both
# redirect URIs in the Google Cloud OAuth client.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_OAUTH_REDIRECT_URI=https://api.example.com/api/youtube/oauth/callback
AUTH_OAUTH_REDIRECT_URI=https://api.example.com/api/auth/google/callback
WEB_BASE_URL=https://app.example.com
SESSION_SECRET=change-me-to-a-long-random-string
YOUTUBE_CATEGORY_ID=24
YOUTUBE_DEFAULT_PRIVACY_STATUS=public
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=600

MAX_UPLOAD_MB=2048
MAX_CANDIDATE_COUNT=30
FINAL_CLIP_COUNT=8
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90
TARGET_CLIP_SECONDS=45
BOUNDARY_REFINE_ENABLED=true
BOUNDARY_MAX_SECONDS=70

FFMPEG_AUDIO_FILTER=loudnorm=I=-16:TP=-1.5:LRA=11,highpass=f=80,lowpass=f=12000
RENDER_VERTICAL_SHORTS=true
SHORTS_REFRAME_MODE=blur
SHORTS_WIDTH=1080
SHORTS_HEIGHT=1920
SHORTS_BACKGROUND_COLOR=black
SHORTS_BLUR_BACKGROUND_STRENGTH=24
SHORTS_SUBTITLES_ENABLED=true
SHORTS_STYLE_PRESET_DEFAULT=korean_pop
SHORTS_SUBTITLE_MODE_DEFAULT=auto
SHORTS_SUBTITLE_FONT_NAME=G마켓 산스 TTF Bold
SHORTS_SUBTITLE_FONTS_DIR=
SHORTS_SUBTITLE_FONT_SIZE=70
SHORTS_SUBTITLE_MARGIN_V=220
SHORTS_SUBTITLE_MAX_CHARS_PER_LINE=16
SHORTS_SUBTITLE_MAX_LINES=2
SHORTS_SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SHORTS_SUBTITLE_HIGHLIGHT_ENABLED=true
SHORTS_SUBTITLE_HIGHLIGHT_COLOR=&H0000E6FF
SHORTS_SUBTITLE_OUTLINE=5
SHORTS_SUBTITLE_SHADOW=2
BURNED_IN_CAPTION_DETECTION_ENABLED=true
BURNED_IN_CAPTION_DETECTION_MAX_FRAMES=6
BURNED_IN_CAPTION_DETECTION_CONFIDENCE_THRESHOLD=0.72
