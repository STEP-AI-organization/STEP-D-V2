{
  "name": "step-d",
  "version": "0.1.0",
  "private": true,
  "description": "STEP-D — UX-first studio (monorepo: web + server). Original STEPD is a separate read-only repo.",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @stepd/web dev",
    "dev:server": "pnpm --filter @stepd/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm -r --parallel start"
  },
  "engines": {
    "node": ">=22"
  }
}
