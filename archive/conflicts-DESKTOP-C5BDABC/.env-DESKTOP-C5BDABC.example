OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_LANGUAGE=ko
OPENAI_TRANSCRIBE_PROMPT=한국어 방송, 예능, 인터뷰, 토크쇼 영상입니다. 사람 이름, 지명, 고유명사, 감탄사, 반말과 존댓말을 가능한 한 원문 그대로 전사하세요.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_EVAL_CANDIDATES=12

DATABASE_URL=sqlite:///./storage/app.db
STORAGE_DIR=./storage
PUBLIC_BASE_URL=http://127.0.0.1:8010

MAX_UPLOAD_MB=2048
MAX_CANDIDATE_COUNT=30
FINAL_CLIP_COUNT=8
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90
TARGET_CLIP_SECONDS=45

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_AUDIO_FILTER=loudnorm=I=-16:TP=-1.5:LRA=11,highpass=f=80,lowpass=f=12000
RENDER_VERTICAL_SHORTS=true
SHORTS_REFRAME_MODE=fit
SHORTS_WIDTH=1080
SHORTS_HEIGHT=1920
SHORTS_BACKGROUND_COLOR=black
SHORTS_TITLE_OVERLAY=true
SHORTS_TITLE_OVERLAY_FALLBACK=false
SHORTS_TITLE_FONT_FILE=
SHORTS_TITLE_FONT_SIZE=72
SHORTS_TITLE_Y_RATIO=0.105
SHORTS_TITLE_LINE_SPACING=18
SHORTS_TITLE_BOX=false
SHORTS_TITLE_BOX_BORDER=22
SHORTS_TITLE_PRIMARY_COLOR=white
SHORTS_TITLE_ACCENT_COLOR=0xFFE600
SHORTS_TITLE_OUTLINE_COLOR=black
SHORTS_TITLE_OUTLINE_WIDTH=5
SHORTS_TITLE_MAX_CHARS_PER_LINE=14
SHORTS_TITLE_MAX_LINES=2

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Register this exact URI in Google Cloud Console OAuth client redirect URIs.
YOUTUBE_OAUTH_REDIRECT_URI=http://127.0.0.1:8010/api/youtube/oauth/callback
WEB_BASE_URL=http://127.0.0.1:3000
# Legacy fallback only. Prefer Google login channel connection in the app.
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CATEGORY_ID=24
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=3600
