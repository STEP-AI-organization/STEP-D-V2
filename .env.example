OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TRANSCRIBE_LANGUAGE=ko
OPENAI_TRANSCRIBE_PROMPT=한국어 방송, 예능, 인터뷰, 토크쇼 영상입니다. 사람 이름, 지명, 고유명사, 감탄사, 반말과 존댓말을 가능한 한 원문 그대로 전사하세요.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_EVAL_CANDIDATES=12

DATABASE_URL=sqlite:///./storage/app.db
STORAGE_DIR=./storage
PUBLIC_BASE_URL=http://127.0.0.1:8010

MAX_UPLOAD_MB=2048
MAX_CANDIDATE_COUNT=30
FINAL_CLIP_COUNT=8
MIN_CLIP_SECONDS=20
MAX_CLIP_SECONDS=90
TARGET_CLIP_SECONDS=45
BOUNDARY_REFINE_ENABLED=true
BOUNDARY_MAX_SECONDS=70
BOUNDARY_START_LOOKBACK_SECONDS=6
BOUNDARY_END_LOOKAHEAD_SECONDS=8
BOUNDARY_PRE_PADDING_SECONDS=0.4
BOUNDARY_POST_PADDING_SECONDS=0.8

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_AUDIO_FILTER=loudnorm=I=-16:TP=-1.5:LRA=11,highpass=f=80,lowpass=f=12000
RENDER_VERTICAL_SHORTS=true
SHORTS_REFRAME_MODE=blur
SHORTS_WIDTH=1080
SHORTS_HEIGHT=1920
SHORTS_BACKGROUND_COLOR=black
SHORTS_BLUR_BACKGROUND_STRENGTH=24
SHORTS_TITLE_OVERLAY=true
SHORTS_TITLE_FONT_FILE=
SHORTS_TITLE_FONT_SIZE=58
SHORTS_TITLE_Y_RATIO=0.095
SHORTS_TITLE_LINE_SPACING=12
SHORTS_TITLE_BOX_BORDER=24
SHORTS_TITLE_MAX_CHARS_PER_LINE=18
SHORTS_TITLE_MAX_LINES=2
SHORTS_VIDEO_FADE_SECONDS=0.15
SHORTS_AUDIO_FADE_SECONDS=0.12
SHORTS_SUBTITLES_ENABLED=true
SHORTS_STYLE_PRESET_DEFAULT=korean_pop
SHORTS_SUBTITLE_MODE_DEFAULT=auto
SHORTS_SUBTITLE_FONT_NAME=G마켓 산스 TTF Bold
SHORTS_SUBTITLE_FONTS_DIR=
SHORTS_SUBTITLE_FONT_SIZE=70
SHORTS_SUBTITLE_MARGIN_V=220
SHORTS_SUBTITLE_MAX_CHARS_PER_LINE=16
SHORTS_SUBTITLE_MAX_LINES=2
SHORTS_SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SHORTS_SUBTITLE_HIGHLIGHT_ENABLED=true
SHORTS_SUBTITLE_HIGHLIGHT_COLOR=&H0000E6FF
SHORTS_SUBTITLE_OUTLINE=5
SHORTS_SUBTITLE_SHADOW=2
BURNED_IN_CAPTION_DETECTION_ENABLED=true
BURNED_IN_CAPTION_DETECTION_MAX_FRAMES=6
BURNED_IN_CAPTION_DETECTION_CONFIDENCE_THRESHOLD=0.72

# YouTube auto-publish (Google OAuth). Create an OAuth client (type: Web application)
# in Google Cloud Console, enable the YouTube Data API v3, and register the redirect
# URI below as an authorized redirect URI. Leave blank to disable the publish button.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_OAUTH_REDIRECT_URI=http://127.0.0.1:8010/api/youtube/oauth/callback
# App login (Google Sign-In identity, separate from the YouTube publish account).
# Register BOTH redirect URIs on the same OAuth client in Google Cloud Console.
AUTH_OAUTH_REDIRECT_URI=http://127.0.0.1:8010/api/auth/google/callback
WEB_BASE_URL=http://localhost:3000
# Secret used to sign login session cookies. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
YOUTUBE_CATEGORY_ID=24
YOUTUBE_DEFAULT_PRIVACY_STATUS=public
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=600

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
